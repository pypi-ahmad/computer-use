# CUA environment variables
# Copy this to .env and fill in values

# API Keys — set these to avoid entering keys in the UI every time.
# The backend resolves keys in priority order: UI input > .env file > system env var.
# GOOGLE_API_KEY=your-google-api-key-here
# GEMINI_API_KEY=your-google-api-key-here   # alias accepted for the google provider
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
# OPENAI_API_KEY=your-openai-api-key-here

# Model override
# GEMINI_MODEL=gemini-3-flash-preview

# OpenAI reasoning effort: none | low | medium | high | xhigh (default: low)
# Higher values improve accuracy but increase cost and latency.
# OPENAI_REASONING_EFFORT=low

# OpenAI API base URL. Defaults to the SDK's built-in
# https://api.openai.com/v1 when unset. Override to a regional
# endpoint (e.g. the US region) or an Azure / proxy deployment.
OPENAI_BASE_URL=https://us.api.openai.com/v1

# Docker
CONTAINER_NAME=cua-environment
SCREEN_WIDTH=1440
SCREEN_HEIGHT=900

# Agent service (inside container)
AGENT_SERVICE_HOST=127.0.0.1
AGENT_SERVICE_PORT=9222

# Shared secret between the backend and the in-container agent service.
# REQUIRED — the agent service refuses to start without it (unless
# CUA_AGENT_INSECURE=1). The host `docker run` launcher auto-generates one;
# set this for the `docker compose up` path. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
AGENT_SERVICE_TOKEN=

# VNC access password. REQUIRED for the compose path (unless CUA_ALLOW_NOPW=1).
VNC_PASSWORD=

# ── INSECURE escape hatches (local dev only — never on a shared host) ────────
# CUA_AGENT_INSECURE=1     # DANGER: run the agent service with NO auth
# CUA_ALLOW_NOPW=1         # DANGER: unauthenticated VNC
# CUA_ALLOW_INTERPRETERS=1 # allow python/node/pip/npm in run_command (ACE risk)

# Agent mode: desktop only
AGENT_MODE=desktop

# Agent
MAX_STEPS=50
STEP_TIMEOUT=30.0

# Debug mode (set to 1 to enable verbose logging)
DEBUG=0

# Backend bind address. Default is loopback only. Binding to 0.0.0.0 (LAN)
# requires BOTH of the following or the process refuses to start:
#   CUA_ALLOW_PUBLIC_BIND=1   # explicit opt-in (typo guard)
#   CUA_WS_TOKEN=<secret>     # shared secret
# When CUA_WS_TOKEN is set it gates /ws and /vnc/websockify AND the
# state-changing REST endpoints (/api/agent/start, /api/container/*,
# /api/files/*, /api/agent-service/mode, /api/keys/validate,
# /api/agent/safety-confirm) — pass it as ?token=<secret> or the
# X-CUA-Token header. Unset (loopback dev) leaves REST default-open.
# HOST=127.0.0.1
# PORT=8100
# CUA_ALLOW_PUBLIC_BIND=
# CUA_WS_TOKEN=
