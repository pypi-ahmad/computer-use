# CUA environment variables
# Copy this to .env and fill in values

# API Keys — set these to avoid entering keys in the UI every time.
# The backend resolves keys in priority order: UI input > .env file > system env var.
# GOOGLE_API_KEY=your-google-api-key-here
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
# OPENAI_API_KEY=your-openai-api-key-here

# Model override
# GEMINI_MODEL=gemini-3-flash-preview

# OpenAI reasoning effort: none | low | medium | high | xhigh (default: low)
# Higher values improve accuracy but increase cost and latency.
# OPENAI_REASONING_EFFORT=low

# Docker
CONTAINER_NAME=cua-environment
SCREEN_WIDTH=1440
SCREEN_HEIGHT=900

# Agent service (inside container)
AGENT_SERVICE_HOST=127.0.0.1
AGENT_SERVICE_PORT=9222

# Agent mode: desktop only
AGENT_MODE=desktop

# Agent
MAX_STEPS=50
STEP_TIMEOUT=30.0
GEMINI_RETRY_ATTEMPTS=3

# Debug mode (set to 1 to enable verbose logging)
DEBUG=0
